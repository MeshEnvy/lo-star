{
  "name": "lo-star",
  "version": "0.0.1",
  "description": "Universal Mesh API",
  "keywords": ["meshcore", "lotato", "cli", "settings", "protobuf", "vfs", "meshtastic"],
  "authors": [{ "name": "Ben Allfree", "maintainer": true }],
  "license": "MIT",
  "homepage": "https://github.com/MeshEnvy/lo-star",
  "repository": {
    "type": "git",
    "url": "https://github.com/MeshEnvy/lo-star.git"
  },
  "frameworks": ["arduino"],
  "platforms": "*",
  "dependencies": {
    "nanopb/Nanopb": "0.4.9+1"
  },
  "build": {
    "libArchive": false,
    "srcDir": ".",
    "srcFilter": [
      "+<locommand/*.cpp>",
      "+<lodb/*.cpp>",
      "+<lofi/*.cpp>",
      "+<lostar/*.cpp>",
      "+<lolog/*.cpp>",
      "+<lomessage/*.cpp>",
      "+<loserial/*.cpp>",
      "+<losettings/*.cpp>",
      "+<losettings/*.pb.c>",
      "+<lofi/*.pb.c>",
      "+<lofs/*.cpp>",
      "+<lofs/backends/*.cpp>",
      "+<louser/*.cpp>",
      "+<louser/*.pb.c>"
    ],
    "flags": [
      "-I lodb/include",
      "-I lolog",
      "-I loserial",
      "-I losettings/include",
      "-I losettings",
      "-I lofi",
      "-I lostar/include",
      "-I lofs/include",
      "-I louser/include",
      "-I louser"
    ]
  }
}
